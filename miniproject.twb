      <aliases enabled='yes' />
      <column caption='Disease Rate' datatype='real' name='[Calculation_0900839098564608]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [disease_label] = 1 THEN 1 ELSE 0 END) / SUM([Calculation_1440423714914307])' />
      </column>
      <column caption='Disease Count' datatype='integer' name='[Calculation_0900839109173249]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [disease_label] = 1 THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Healthy Count' datatype='integer' name='[Calculation_0900839109951490]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [disease_label] = 2 THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Disease_Rate' datatype='real' name='[Calculation_0900839110664195]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [disease_label] = 1 THEN 1 ELSE 0 END) / COUNT([disease_label])' />
      </column>
      <column caption='Norm ALT' datatype='real' name='[Calculation_0900839122923524]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([ALT] - 7) / (2000 - 7) * 100' />
      </column>
      <column caption='Norm AST' datatype='real' name='[Calculation_0900839123152901]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([AST] - 10) / (4929 - 10) * 100' />
      </column>
      <column caption='Norm Bilirubin' datatype='real' name='[Calculation_0900839123238918]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([total_bilirubin] - 0.2) / (75 - 0.2) * 100' />
      </column>
      <column caption='Norm Albumin' datatype='real' name='[Calculation_0900839123451911]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([albumin] - 0.9) / (5.5 - 0.9) * 100' />
      </column>
      <column caption='Norm ALP' datatype='real' name='[Calculation_0900839123574792]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([alkaline_phosphotase] - 44) / (2110 - 44) * 100' />
      </column>
      <column caption='Norm Proteins' datatype='real' name='[Calculation_0900839123800073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([total_proteins] - 2.7) / (9.6 - 2.7) * 100' />
      </column>
      <column caption='Norm AG Ratio' datatype='real' name='[Calculation_0900839124037642]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([albumin_globulin_ratio] - 0.3) / (2.8 - 0.3) * 100' />
      </column>
      <column caption='Disease Status' datatype='string' name='[Calculation_1440423713603585]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [disease_label] = 1 THEN &quot;Liver Disease&quot; ELSE &quot;Healthy&quot; END' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_1440423713796098]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age] &lt; 30 THEN &quot;Under 30&quot;&#13;&#10;ELSEIF [age] &lt; 45 THEN &quot;30-44&quot;&#13;&#10;ELSEIF [age] &lt; 60 THEN &quot;45-59&quot;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;END' />
      </column>
      <column caption='Number of Records' datatype='integer' name='[Calculation_1440423714914307]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
